# Database (Supabase PostgreSQL)
DATABASE_URL=

# AI
ANTHROPIC_API_KEY=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.ca

# Auth
JWT_SECRET=
DEV_AUTH_BYPASS=true                   # Set to true + NODE_ENV=development to bypass auth locally

# Rate Limiting (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App
# MUST be the exact canonical host Netlify serves (e.g. use the www form if
# Netlify redirects apex→www). The server-side trigger POSTs to
# ${NEXT_PUBLIC_APP_URL}/.netlify/functions/generate-briefing — a 301
# apex→www redirect drops the POST body, causing every investigation to be
# marked failed immediately. Verify: curl -sI https://yourdomain.ca | grep location
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Internal trigger secret for Netlify Background Functions
# Used to authenticate POST /.netlify/functions/generate-briefing from the
# Next.js routes. NOT added to env.ts (strict zod parse would throw at boot
# if missing). Generate with: openssl rand -hex 32
# Must be set in all Netlify environments (prod + previews) before deploy.
INTERNAL_TRIGGER_SECRET=

# Analytics (optional -- omit to disable)
NEXT_PUBLIC_ANALYTICS_SCRIPT_URL=
NEXT_PUBLIC_ANALYTICS_ENDPOINT=
NEXT_PUBLIC_ANALYTICS_SITE_ID=

# Error Monitoring (Sentry -- optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# ActivityPub Federation
# IMMUTABLE once federation is live. Changing this after any user has federated
# breaks ALL existing actor identities. Treat this like a primary key.
AP_DOMAIN=

# Archive (Phase 2)
PINATA_JWT=
PINATA_GATEWAY=
IRYS_PRIVATE_KEY=
IRYS_NETWORK=devnet
ARWEAVE_GATEWAY=https://arweave.net
ENABLE_ARWEAVE=false
