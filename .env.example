# Database (Supabase PostgreSQL)
DATABASE_URL=

# AI
ANTHROPIC_API_KEY=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@therepublic.ca

# Auth
JWT_SECRET=
DEV_AUTH_BYPASS=true                   # Set to true + NODE_ENV=development to bypass auth locally

# Rate Limiting (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Error Monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# ActivityPub Federation
# IMMUTABLE once federation is live. Changing this after any user has federated
# breaks ALL existing actor identities. Treat this like a primary key.
AP_DOMAIN=

# Archive (Phase 2)
PINATA_JWT=
PINATA_GATEWAY=
IRYS_PRIVATE_KEY=
IRYS_NETWORK=devnet
ARWEAVE_GATEWAY=https://arweave.net
ENABLE_ARWEAVE=false
