# Database (Supabase)
DATABASE_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI
ANTHROPIC_API_KEY=

# Search (Tavily)
TAVILY_API_KEY=

# Auth
JWT_SECRET=

# Rate Limiting (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ActivityPub Federation
# IMMUTABLE once federation is live. Example: republic.example.com
# Changing this value after any user has federated breaks ALL existing actor
# identities (actor URIs are keyed on this domain) and severs remote followers.
# There is no migration path — treat this like a primary key.
AP_DOMAIN=

# Archive (Phase 2)
PINATA_JWT=                            # Pinata SDK JWT for IPFS pinning
PINATA_GATEWAY=                        # Your Pinata gateway subdomain (e.g., your-gateway.mypinata.cloud)
IRYS_PRIVATE_KEY=                      # (Optional) Hot wallet key for Arweave via Irys
IRYS_NETWORK=devnet                    # Irys network: mainnet or devnet
ARWEAVE_GATEWAY=https://arweave.net    # Arweave gateway URL
ENABLE_ARWEAVE=false                   # Enable Arweave permanence (requires funded Irys wallet)
